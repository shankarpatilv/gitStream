# Copy this file to a private shell env file, fill the values, then source it.
# Do not commit real values.

export GITSTREAM_FLY_PREFIX="gitstream-demo-yourname"
export FLY_REGION="iad"
export FLY_ORG="personal"

export POSTGRES_PASSWORD="replace-with-demo-password"
export CLICKHOUSE_PASSWORD="replace-with-demo-password"

# External cloud Kafka is required for the live Fly demo.
export KAFKA_BROKERS="pkc-example.us-east-1.aws.confluent.cloud:9092"
export KAFKA_USERNAME="replace-with-kafka-api-key"
export KAFKA_PASSWORD="replace-with-kafka-api-secret"

# Optional, but recommended to avoid low unauthenticated GitHub API limits.
export GITHUB_TOKEN="replace-with-github-token-or-leave-empty"
